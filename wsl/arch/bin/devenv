#!/usr/bin/env bash
set -Eeuo pipefail

self="$(readlink -f "${BASH_SOURCE[0]}")"
self_dir="$(cd -- "$(dirname -- "$self")" && pwd)"

if [[ -z "${DEVENV_ROOT:-}" ]]; then
    # This file lives at: <repo>/wsl/arch/bin/devenv
    DEVENV_ROOT="$(cd -- "$self_dir/../../.." && pwd)"
fi

ARCH_DIR="$DEVENV_ROOT/wsl/arch"
COMPONENT_DIR="$ARCH_DIR/components"
DOTFILES_SOURCE="$DEVENV_ROOT/env/.config"

ORDERED_TARGETS=(
    pacman
    user
    sudo
    xdg
    git
    base
    bin
    zsh
    neovim
    dotfiles
    dotnet
    opencode
    workspaces
)

LITE_TARGETS=(
    base
    bin
    zsh
    neovim
    dotfiles
)

log() {
    printf '\033[1;34m[devenv]\033[0m %s\n' "$*"
}

warn() {
    printf '\033[1;33m[devenv:warn]\033[0m %s\n' "$*" >&2
}

die() {
    printf '\033[1;31m[devenv:error]\033[0m %s\n' "$*" >&2
    exit 1
}

dotfiles_user() {
    if [[ "${EUID}" -eq 0 && -n "${SUDO_USER:-}" && "${SUDO_USER}" != root ]]; then
        printf '%s\n' "$SUDO_USER"
        return
    fi

    printf '%s\n' "${USER:-$(id -un)}"
}

dotfiles_target() {
    local target_user home_dir

    if [[ -n "${XDG_CONFIG_HOME:-}" && "${EUID}" -ne 0 ]]; then
        printf '%s\n' "$XDG_CONFIG_HOME"
        return
    fi

    target_user="$(dotfiles_user)"
    home_dir="$(getent passwd "$target_user" | cut -d: -f6)"
    [[ -n "$home_dir" ]] || die "Could not resolve home directory for user: $target_user"

    printf '%s\n' "$home_dir/.config"
}

DOTFILES_TARGET="$(dotfiles_target)"

usage() {
    cat <<EOF_USAGE
Usage:
  devenv install <target...>   Run component scripts or presets in WSL order
  devenv update                Pull the Linux devenv repo and update submodules
  devenv list                  List available Linux component scripts
  devenv dotfiles              Replace managed env/.config entries in XDG_CONFIG_HOME
  devenv doctor                Print basic devenv/WSL diagnostics
  devenv help                  Show this help

presets:
  lite                          base bin zsh neovim dotfiles
EOF_USAGE
}

ensure_repo() {
    [[ -d "$DEVENV_ROOT/.git" ]] || die "DEVENV_ROOT is not a git repo: $DEVENV_ROOT"
}

is_ordered_target() {
    local target="$1"
    local ordered_target

    for ordered_target in "${ORDERED_TARGETS[@]}"; do
        [[ "$target" == "$ordered_target" ]] && return 0
    done

    return 1
}

add_install_target() {
    local target="$1"
    local -n requested_ref="$2"

    if ! is_ordered_target "$target"; then
        die "Unknown install target: $target. Try: devenv list"
    fi

    if [[ "$target" != dotfiles && ! -f "$COMPONENT_DIR/${target}.sh" ]]; then
        die "Install target has no component script: $target"
    fi

    requested_ref["$target"]=1
}

add_install_arg() {
    local arg="$1"
    local preset_target

    case "$arg" in
        lite)
            for preset_target in "${LITE_TARGETS[@]}"; do
                add_install_target "$preset_target" "$2"
            done
            ;;
        *)
            add_install_target "$arg" "$2"
            ;;
    esac
}

run_install_target() {
    local target="$1"

    if [[ "$target" == dotfiles ]]; then
        command_dotfiles
        return
    fi

    local script="$COMPONENT_DIR/${target}.sh"
    [[ -f "$script" ]] || die "Unknown component: $target. Try: devenv list"

    log "Running component: $target"
    export DEVENV_ROOT
    bash "$script"
}

command_install() {
    [[ "$#" -gt 0 ]] || die "Missing install target. Try: devenv list"

    local -A requested=()
    local arg ordered_target

    for arg in "$@"; do
        add_install_arg "$arg" requested
    done

    for ordered_target in "${ORDERED_TARGETS[@]}"; do
        if [[ -n "${requested[$ordered_target]:-}" ]]; then
            run_install_target "$ordered_target"
        fi
    done
}

command_update() {
    ensure_repo
    log "Updating repo: $DEVENV_ROOT"
    git -C "$DEVENV_ROOT" pull --ff-only
    git -C "$DEVENV_ROOT" submodule update --init --recursive
}

command_list() {
    local ordered_target

    [[ -d "$COMPONENT_DIR" ]] || die "Component directory not found: $COMPONENT_DIR"

    for ordered_target in "${ORDERED_TARGETS[@]}"; do
        if [[ "$ordered_target" == dotfiles || -f "$COMPONENT_DIR/${ordered_target}.sh" ]]; then
            printf '%s\n' "$ordered_target"
        fi
    done
}

command_dotfiles() {
    [[ -d "$DOTFILES_SOURCE" ]] || die "Dotfiles source not found: $DOTFILES_SOURCE"

    case "$DOTFILES_TARGET" in
        */.config) ;;
        *) die "Refusing to copy dotfiles because XDG_CONFIG_HOME does not end with .config: $DOTFILES_TARGET" ;;
    esac

    mkdir -p "$DOTFILES_TARGET"
    log "Removing existing managed dotfiles"
    for source_item in "$DOTFILES_SOURCE"/* "$DOTFILES_SOURCE"/.[!.]* "$DOTFILES_SOURCE"/..?*; do
        [[ -e "$source_item" ]] || continue
        rm -rf -- "$DOTFILES_TARGET/$(basename "$source_item")"
    done

    log "Copying dotfiles"
    log "Source: $DOTFILES_SOURCE"
    log "Target: $DOTFILES_TARGET"
    rsync -av "$DOTFILES_SOURCE/" "$DOTFILES_TARGET/"

    if [[ "${EUID}" -eq 0 ]]; then
        local target_user target_group source_item target_item
        target_user="$(dotfiles_user)"
        target_group="$(id -gn "$target_user")"

        for source_item in "$DOTFILES_SOURCE"/* "$DOTFILES_SOURCE"/.[!.]* "$DOTFILES_SOURCE"/..?*; do
            [[ -e "$source_item" ]] || continue
            target_item="$DOTFILES_TARGET/$(basename "$source_item")"
            [[ -e "$target_item" ]] || continue
            chown -R "$target_user:$target_group" "$target_item"
        done
    fi
}

command_doctor() {
    cat <<EOF_DOCTOR
DEVENV_ROOT=$DEVENV_ROOT
ARCH_DIR=$ARCH_DIR
COMPONENT_DIR=$COMPONENT_DIR
XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-}
DOTFILES_SOURCE=$DOTFILES_SOURCE
DOTFILES_TARGET=$DOTFILES_TARGET
USER=${USER:-}
SHELL=${SHELL:-}
WSL_DISTRO_NAME=${WSL_DISTRO_NAME:-}
EOF_DOCTOR

    if grep -qiE '(microsoft|wsl)' /proc/sys/kernel/osrelease 2>/dev/null; then
        log "WSL detected"
    else
        warn "WSL not detected"
    fi
}

cmd="${1:-help}"
shift || true

case "$cmd" in
    install) command_install "$@" ;;
    update) command_update "$@" ;;
    list) command_list "$@" ;;
    dotfiles) command_dotfiles "$@" ;;
    doctor) command_doctor "$@" ;;
    help|-h|--help) usage ;;
    *)
        usage >&2
        die "Unknown command: $cmd"
        ;;
esac
